          type: code
          content: >-
            # 1. Ver cuántos datos hay por cada ciudad

            print("--- Cantidad de registros por Localidad ---")

            print(df['Localidad'].value_counts())


            # 2. Ver la "Moda" (La ciudad que más aparece en el dataset)

            print(f"\nLa Localidad con más registros (Moda) es: {df['Localidad'].mode()[0]}")


            # 3. Gráfico para el informe (Visualización cualitativa)

            plt.figure(figsize=(10,6))

            sns.countplot(y='Localidad', data=df, palette='viridis', order=df['Localidad'].value_counts().index)

            plt.title('Distribución de Datos por Localidad')

            plt.xlabel('Número de Observaciones')

            plt.show()
