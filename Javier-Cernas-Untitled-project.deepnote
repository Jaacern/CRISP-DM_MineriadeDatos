          type: code
          content: >-
            # Análisis estadístico de la Precipitación

            stats_precip = df['precipitation'].describe()


            print("--- Estadísticos Descriptivos: Precipitación (mm) ---")

            print(stats_precip)


            # Calculamos la mediana por separado (que no siempre viene en describe)

            print(f"Mediana: {df['precipitation'].median()} mm")


            # Visualización para la interpretación

            plt.figure(figsize=(8,5))

            sns.histplot(df['precipitation'], bins=30, kde=True, color='blue')

            plt.title('Distribución de la Precipitación')

            plt.xlabel('Precipitación (mm)')

            plt.ylabel('Frecuencia (Horas)')

            plt.show()
