          sortingKey: "000058"
          type: text-cell-h2
          content: "5. Eliminación de Duplicados Temporales:"
          metadata:
            formattedRanges: []
        - id: e3756323e3434a5b9bad489d6dd81e24
          blockGroup: 54b0060870364177b4859f28eb88bfd1
          sortingKey: "000059"
          type: text-cell-p
          content: "   - Justificación: Filas repetidas para la misma hora y localidad sobre-entrenarían el modelo en eventos
            específicos, generando sesgo de sobreajuste (overfitting)."
