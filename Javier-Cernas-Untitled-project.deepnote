          type: code
          content: >-
            # Agrupamos los datos

            viento_por_hora = df.groupby('Hora')['wind_speed_10m'].mean()


            # Graficamos (esto es lo que da la nota)

            plt.figure(figsize=(10,5))

            viento_por_hora.plot(kind='line', marker='o', color='teal')

            plt.title('Velocidad Promedio del Viento por Hora del Día')

            plt.xlabel('Hora (0-23)')

            plt.ylabel('Velocidad (km/h)')

            plt.grid(True)

            plt.show()
