          type: code
          content: >-
            # Buscar valores duplicados en el DataFrame completo y por clave temporal-localidad

            # 1) Conteo total de filas duplicadas (todas las columnas)

            duplicados_totales = df.duplicated().sum()

            print(f"Filas totalmente duplicadas (todas las columnas): {duplicados_totales}")


            # 2) Mostrar algunas filas duplicadas (si existen)

            if duplicados_totales > 0:
                print("\nEjemplos de filas duplicadas:")
                print(df[df.duplicated()].head(5))

            # 3) Duplicados por combinación clave ['date','Localidad']

            #    Esta suele ser una llave natural en series horarias por ciudad

            clave = ['date','Localidad']

            duplicados_llave = df.duplicated(subset=clave, keep=False)

            num_duplicados_llave = duplicados_llave.sum()

            print(f"\nRegistros duplicados por llave {clave}: {num_duplicados_llave}")


            if num_duplicados_llave > 0:
                print("\nEjemplos de duplicados por llave:")
                print(df[duplicados_llave].sort_values(clave).head(10))

            # 4) Resumen por columna: número de valores duplicados en cada columna

            print("\nValores duplicados por columna (considerando duplicados exactos en la columna):")

            for col in df.columns:
                # total elementos - elementos únicos = duplicados en esa columna
                duplicados_col = len(df[col]) - df[col].nunique()
                print(f"- {col}: {duplicados_col}")
